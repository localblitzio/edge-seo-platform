{
  "name": "edge-seo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers edge SEO platform — proxy, transform, and serve client sites at the edge.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:routes": "node scripts/check-route-drift.mjs",
    "predeploy:staging": "node scripts/check-route-drift.mjs --env staging",
    "deploy:staging": "wrangler deploy --env staging",
    "predeploy:production": "node scripts/check-route-drift.mjs --env production",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate:staging": "wrangler d1 migrations apply CONFIG_DB --env staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply CONFIG_DB --env production --remote",
    "db:migrate:local": "wrangler d1 migrations apply CONFIG_DB --local",
    "wrangler:types": "wrangler types",
    "demo:seed": "node scripts/seed-demo.mjs",
    "demo:reset": "rimraf .wrangler/state && node scripts/seed-demo.mjs",
    "admin": "node admin-ui/server.mjs",
    "config:validate": "tsx scripts/validate-config.ts",
    "seed-client": "tsx scripts/seed-client.ts",
    "load-test": "node scripts/load-test.mjs",
    "smoke": "node scripts/post-deploy-smoke.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@vitest/coverage-v8": "^2.1.9",
    "miniflare": "^3.20250109.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9",
    "wrangler": "^3.114.17"
  }
}
